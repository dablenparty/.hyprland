_pkgname="hyprpolkitagent"
pkgname="$_pkgname-git"
pkgver=0.1.3.r7.ga259bf1
pkgrel=1
pkgdesc="A polkit authentication agent written in QT/QML"
arch=('x86_64' 'aarch64')
url="https://github.com/hyprwm/$_pkgname"
license=('BSD-3-Clause')

depends=(
  hyprgraphics-git libhyprgraphics.so
  hyprlang-git libhyprlang.so
  hyprtoolkit-git libhyprtoolkit.so
  hyprutils-git libhyprutils.so
  libdrm
  pixman libpixman-1.so
  'sdbus-cpp>=2.0.0' libsdbus-c++.so
)
makedepends=(
  abseil-cpp
  cmake
  git
  ninja
)
provides=("$_pkgname=${pkgver%%.r*}" "lib$_pkgname.so")
conflicts=("$_pkgname")
source=("git+$url.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/$_pkgname" || exit

  printf "%s" "${ git describe --long --tags --abbrev=7 | sed 's/^v//;s/\([^-]*-g\)/r\1/;s/-/./g'; }"
}

prepare() {
  cd "$srcdir/$_pkgname" || exit

  local cmake_options=(
    -B build
    -S .
    -G Ninja
    -W no-dev
    -D CMAKE_BUILD_TYPE=Release
    -D CMAKE_INSTALL_PREFIX=/usr
  )
  cmake "${cmake_options[@]}"
}

build() {
  cd "$srcdir/$_pkgname" || exit

  cmake --build build
}

package() {
  cd "$srcdir/$_pkgname" || exit

  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "$srcdir/$_pkgname/LICENSE" -t "$pkgdir/usr/share/licenses/$pkgname/"
}
